{
  "name": "prestige-tools",
  "version": "0.15.0",
  "private": true,
  "description": "MCOC prestige optimisation tools — Phase 1 web app",
  "scripts": {
    "dev": "pnpm -F web dev",
    "build": "pnpm -F @prestige-tools/engine build && pnpm -F web build",
    "test": "pnpm -F @prestige-tools/engine test",
    "seed": "tsx scripts/seed-from-mcochub.ts",
    "scrape-portraits": "tsx scripts/scrape-fandom-portraits.ts",
    "refresh-classes": "tsx scripts/refresh-classes-from-fandom.ts",
    "refresh-bhr": "tsx scripts/refresh-bhr-from-mcochub.ts",
    "refresh-bhr-r4": "tsx scripts/refresh-bhr-from-mcocgg.ts",
    "refresh-synergies": "tsx scripts/refresh-synergies-from-mcocgg.ts",
    "refresh-abilities": "tsx scripts/refresh-abilities-from-mcochub.ts",
    "backfill-immunities": "tsx scripts/backfill-immunities-from-mcochub.ts",
    "parse-immunity-kits": "tsx scripts/parse-immunities-from-abilities.ts",
    "lint": "pnpm -F web lint"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
